{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://artfest.onrender.com/sitemap.xml"
    },
    {
      "source": "/google-shopping-feed.xml",
      "destination": "https://artfest.onrender.com/google-shopping-feed.xml"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://artfest.onrender.com/api/$1"
    },
    {
      "source": "/legal/(.*)",
      "destination": "https://artfest.onrender.com/legal/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
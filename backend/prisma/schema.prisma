model VendorEarningEntry {
  id               String            @id @default(cuid())
  vendorId         String
  shipmentId       String?           @unique
  orderId          String?
  type             VendorEarningType @default(SALE)
  occurredAt       DateTime          @default(now())
  currency         String            @default("RON") @db.VarChar(8)
  itemsNet         Decimal           @default(0) @db.Decimal(12, 2)
  commissionNet    Decimal           @default(0) @db.Decimal(12, 2)
  vendorNet        Decimal           @default(0) @db.Decimal(12, 2)
  payoutId         String?
  meta             Json?
  createdAt        DateTime          @default(now())
  stripeTransferId String?           @db.VarChar(255)

  vendor   Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  shipment Shipment?     @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  order    Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  payout   VendorPayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@index([stripeTransferId])
  @@index([vendorId, occurredAt])
  @@index([vendorId, payoutId])
  @@index([orderId])
}

model VendorPayout {
  id                 String        @id @default(cuid())
  vendorId           String
  periodFrom         DateTime
  periodTo           DateTime
  currency           String        @default("RON") @db.VarChar(8)
  totalItemsNet      Decimal       @default(0) @db.Decimal(12, 2)
  totalCommissionNet Decimal       @default(0) @db.Decimal(12, 2)
  totalVendorNet     Decimal       @default(0) @db.Decimal(12, 2)
  invoiceId          String?       @unique
  status             InvoiceStatus @default(UNPAID)
  issuedAt           DateTime      @default(now())
  paidAt             DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  vendor  Vendor               @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  invoice Invoice?             @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  entries VendorEarningEntry[]

  @@index([vendorId, periodFrom, periodTo])
}

enum ReturnRequestStatus {
  NEW
  IN_REVIEW
  APPROVED
  REJECTED
  PICKUP_REQUESTED
  CLOSED
}

model ReturnRequest {
  id                 String              @id @default(cuid())
  userId             String?
  orderId            String
  originalShipmentId String
  vendorId           String
  status             ReturnRequestStatus @default(NEW)
  reasonCode         String
  reasonText         String?
  faultParty         String?
  resolutionWanted   String?
  notesUser          String?
  photos             String[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  user             User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  order            Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  originalShipment Shipment            @relation("ReturnOriginalShipment", fields: [originalShipmentId], references: [id], onDelete: Cascade)
  vendor           Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  items            ReturnRequestItem[]
  returnShipments  Shipment[]

  @@index([orderId, createdAt])
  @@index([vendorId, createdAt])
  @@index([status, createdAt])
  @@index([originalShipmentId])
}

model ReturnRequestItem {
  id              String  @id @default(cuid())
  returnRequestId String
  shipmentItemId  String?
  productId       String?
  title           String
  qty             Int
  price           Decimal @db.Decimal(10, 2)

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
  @@index([productId])
}

model StripeEvent {
  id          String    @id @default(cuid())
  eventId     String    @unique
  type        String
  livemode    Boolean   @default(false)
  payload     Json?
  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  error       String?

  @@index([type, receivedAt])
  @@index([processedAt])
}

enum StripeConnectStatus {
  not_started
  pending
  enabled
  restricted
}

model NewsletterSubscriber {
  id             String           @id @default(cuid())
  email          String           @unique
  userId         String?
  status         NewsletterStatus @default(SUBSCRIBED)
  source         NewsletterSource @default(FOOTER)
  sourceLabel    String?
  notes          String?
  subscribedAt   DateTime         @default(now())
  unsubscribedAt DateTime?
  lastSentAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status, createdAt])
  @@index([source, createdAt])
  @@index([subscribedAt])
  @@index([unsubscribedAt])
}

enum NewsletterStatus {
  SUBSCRIBED
  UNSUBSCRIBED
}

enum NewsletterSource {
  FOOTER
  ADMIN
  IMPORT
  CHECKOUT
  CONTACT
  OTHER
}
